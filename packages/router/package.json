  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vitarx-lib/router"
  },
  "homepage": "https://vitarx.cn/router",
  "keywords": [
    "vitarx",
    "router",
    "vitarx-router"
  ],
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "check:circular": "madge --extensions js --circular dist --warning --exclude '.*\\\\.d\\\\.ts$'",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vitarx": "^4.0.0-0"
  },
